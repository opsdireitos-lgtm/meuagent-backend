# ══════════════════════════════════════════════
# MeuAgent VPS Backend - Environment Variables
# ══════════════════════════════════════════════

# ── Supabase (fonte dos dados) ──
SUPABASE_URL=https://cwkeaewvnirvmkuodsjx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ── PostgreSQL Local (cache/logs) ──
DATABASE_URL=postgresql://meuagent:meuagent_pass@postgres:5432/meuagent

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Servidor ──
PORT=3333
NODE_ENV=production

# ── Evolution API ──
EVOLUTION_API_URL=http://sua-vps:8080
EVOLUTION_API_KEY=sua_api_key_evolution

# ── Workers (ms) ──
FOLLOW_UP_POLL_INTERVAL=30000
BULK_POLL_INTERVAL=60000
STALE_LOCK_MINUTES=5
